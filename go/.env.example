# mapene-mcp (Black Swan) — environment configuration
# Copy to go/.env and adjust values for your deployment.

# Fineract backend (env var names are a config contract; do not rename)
MIFOSX_BASE_URL=https://localhost:8443/fineract-provider/api/v1
MIFOSX_TENANT_ID=default
MIFOSX_USERNAME=mifos
MIFOSX_PASSWORD=password

# Transport: if PORT is set, run HTTP/SSE on that port; otherwise run stdio.
# PORT=8080

# Security (HTTP/SSE mode)
# Fail-closed: with MCP_AUTH_TOKEN unset, only /health responds; all other
# routes return 401. Set it and send 'Authorization: Bearer <token>'.
# MCP_AUTH_TOKEN=change-me
# CORS is same-origin unless an explicit origin is opted in here.
# MCP_ALLOWED_ORIGIN=https://your-app.example.com
